---
<div class="relative w-full h-full group">
  
  <button 
    id="prev-btn"
    class="absolute left-4 top-1/2 -translate-y-1/2 z-20 bg-black/30
      hover:bg-black/50 text-white p-4 rounded-full cursor-pointer transition-all focus:outline-none"
    aria-label="Previous slide"
  >
    &lt;
  </button>

  <div
    id="hero-scroll-container"
    class="flex items-center h-full bg-blue-600
      [scrollbar-width:none] [&::-webkit-scrollbar]:hidden"
    style="
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scroll-behavior: smooth;
      overflow-y: hidden;"
  >
    {
      contentBlocks && contentBlocks.length > 1 && (
        contentBlocks.map((block, i) => (
          <section
            class="relative flex items-center justify-items"
            style="
              flex: 0 0 100%;
              scroll-snap-align: start;"
            id={`slide-${i + 1}`}
          >
            <div
              class="font-body prose-invert max-w-none
                prose-sm md:prose-base lg:prose-lg
                prose-a:text-red-200
                prose-a:hover:text-red-100 prose-il:text-red-500
                prose-ul:list-disc prose-ul:pl-6
                prose-ol:list-decimal prose-ol:pl-6
                prose-li:marker:text-slate-400
                prose-blockquote:border-l-4
                prose-blockquote:border-slate-500
                prose-blockquote:pl-6
                prose-blockquote:italic
                prose-blockquote:text-slate-400
                prose-blockquote:not-prose"
            >
              <BlockContent block={block}></BlockContent>
            </div>
          </section>
        ))
      )
    }
  </div>

  <button 
    id="next-btn"
    class="absolute right-4 top-1/2 -translate-y-1/2 z-20 bg-black/30
      hover:bg-black/50 text-white p-4 rounded-full cursor-pointer transition-all focus:outline-none"
    aria-label="Next slide"
  >
    &gt;
  </button>
</div>

<script>
  const container = document.getElementById('hero-scroll-container') as HTMLElement;
  const previousButton = document.getElementById('prev-btn');
  const nextButton = document.getElementById('next-btn');

  nextButton?.addEventListener('click', () => {
    const CURRENT_SCROLL = container.scrollLeft;
    const SLIDE_WIDTH = container.offsetWidth;
    
    const NEXT_STROLL = CURRENT_SCROLL + SLIDE_WIDTH;
    
    if (NEXT_STROLL >= container.scrollWidth) {
      container.scrollTo({ left: 0, behavior: 'smooth' });
    } else {
      container.scrollBy({ left: SLIDE_WIDTH, behavior: 'smooth' });
    }
  });

  previousButton?.addEventListener('click', () => {
    const CURRENT_SCROLL = container.scrollLeft;
    const SLIDE_WIDTH = container.offsetWidth;
    
    if (CURRENT_SCROLL <= 0) {
      container.scrollTo({ left: container.scrollWidth, behavior: 'smooth' });
    } else {
      container.scrollBy({ left: -SLIDE_WIDTH, behavior: 'smooth' });
    }
  });
</script>
